# Скопируй этот файл в .env и заполни значения

# Секретный ключ для сессий (любая случайная строка, мин 32 символа)
PANEL_SECRET=замени_на_случайную_строку_минимум_32_символа

# Пароль для дефолтного admin аккаунта (создаётся при первом запуске)
ADMIN_PASSWORD=замени_на_свой_пароль

# Google reCAPTCHA v3 (получи на https://www.google.com/recaptcha)
# Оставь пустым чтобы отключить капчу
RECAPTCHA_SITE=
RECAPTCHA_SECRET=

# Порт (Railway подставляет автоматически)
PORT=8000
